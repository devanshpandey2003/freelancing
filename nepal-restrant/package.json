{
  "name": "haveli-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=apps/server\" \"npm run dev --workspace=apps/web\"",
    "build": "npm run build --workspace=apps/web && npm run build --workspace=apps/server",
    "db:generate": "npm run generate --workspace=packages/prisma",
    "db:migrate": "npm run migrate --workspace=packages/prisma",
    "db:seed": "npm run seed --workspace=packages/prisma",
    "db:studio": "npm run studio --workspace=packages/prisma"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
